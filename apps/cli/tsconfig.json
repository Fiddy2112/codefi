{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "lib": ["ES2022"],
      "moduleResolution": "nodenext",
      "resolveJsonModule": true,
      "allowJs": true,
      "outDir": "./dist",
      "rootDir": "./src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "declaration": true,
      "declarationMap": true,
      "sourceMap": true,
      "jsx": "react",
      "baseUrl": ".",
      "paths": {
        "@/*": ["./src/*"],
        "@commands/*": ["./src/commands/*"],
        "@services/*": ["./src/services/*"],
        "@ui/*": ["./src/ui/*"],
        "@utils/*": ["./src/utils/*"]
      }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
  }