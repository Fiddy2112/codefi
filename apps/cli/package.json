{
    "name": "@codefi/cli",
    "version": "0.1.0",
    "description": "Brewing beats for your code - CLI tool",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "codefi": "./bin/codefi.js"
    },
    "scripts": {
        "dev": "tsx src/index.ts",
        "dev:watch": "tsx watch src/index.ts",
        "build": "tsup src/index.ts --format cjs,esm --dts --clean",
        "build:prod": "npm run build && node scripts/bundle-production.js",
        "start": "node bin/codefi.js",
        "test": "vitest",
        "lint": "eslint src --ext .ts,.tsx",
        "type-check": "tsc --noEmit"
    },
    "keywords": [
        "cli",
        "music",
        "productivity",
        "lofi",
        "developer-tools",
        "terminal"
    ],
    "author": "Fiddy",
    "license": "MIT",
    "dependencies": {
        "@oclif/core": "^4.8.0",
        "@supabase/supabase-js": "^2.99.1",
        "axios": "^1.13.5",
        "boxen": "^5.1.2",
        "chalk": "^4.1.2",
        "commander": "^11.1.0",
        "conf": "10.2.0",
        "dotenv": "^16.6.1",
        "ink": "^4.4.1",
        "inquirer": "^8.2.6",
        "log-update": "^4.0.0",
        "node-notifier": "^10.0.1",
        "open": "^11.0.0",
        "ora": "5.4.1",
        "play-sound": "^1.1.6",
        "react": "^18.2.0"
    },
    "devDependencies": {
        "@types/axios": "^0.14.4",
        "@types/inquirer": "^8.2.10",
        "@types/node": "^20.19.33",
        "@types/react": "^18.2.0",
        "eslint": "^8.55.0",
        "nodemon": "^3.1.11",
        "ts-node": "^10.9.2",
        "tsup": "^8.0.1",
        "tsx": "^4.7.0",
        "typescript": "^5.9.3",
        "vitest": "^1.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
