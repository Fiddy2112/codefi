# Audio Service
DEFAULT_VOLUME=70
AUDIO_FORMAT=mp3

# Config
CONFIG_DIR=~/.codefi
TRACKS_DIR=~/.codefi/tracks

# Supabase (For Pro features)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Spotify (For Pro features)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OpenAI (For AI mood detection - Pro)
OPENAI_API_KEY=

# App Settings
LOG_LEVEL=info
NODE_ENV=development