---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout title="404 - Transmission Lost | CodeFi">
  <div class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="max-w-2xl w-full text-center relative">
      <!-- Glitchy Error Code -->
      <div class="relative inline-block mb-12">
        <h1 class="text-[12rem] font-bold text-white/5 leading-none select-none tracking-tighter">
          404
        </h1>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-6xl md:text-8xl font-bold text-white glitch-text" data-text="ERROR">
            ERROR
          </span>
        </div>
      </div>

      <!-- Warning Message -->
      <div class="space-y-6 relative z-10">
        <div class="inline-block px-3 py-1 rounded bg-red-500/10 border border-red-500/20 text-red-500 text-xs font-mono mb-4">
          TRANSMISSION_INTERRUPTED
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-white">
          Signal lost in the <span class="text-neon-green italic">Static</span>.
        </h2>
        <p class="text-cyber-text text-lg max-w-md mx-auto">
          The page you are looking for has been de-indexed or moved to a restricted sector.
        </p>
      </div>

      <!-- Actions -->
      <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" href="/">
          Return to Hub
        </Button>
        <Button variant="ghost" href="/docs">
          Search Archives
        </Button>
      </div>

      <!-- Background Decoration -->
      <div class="absolute -top-1/2 left-1/2 -translate-x-1/2 w-96 h-96 bg-neon-green/5 rounded-full blur-[120px] -z-10"></div>
    </div>
  </div>
</BaseLayout>

<style>
  .glitch-text {
    position: relative;
    text-shadow: 0.05em 0 0 rgba(255, 0, 0, 0.75),
                 -0.025em -0.05em 0 rgba(0, 255, 0, 0.75),
                 0.025em 0.05em 0 rgba(0, 0, 255, 0.75);
    animation: glitch 500ms infinite;
  }

  @keyframes glitch {
    0% {
      text-shadow: 0.05em 0 0 rgba(255, 0, 0, 0.75),
                   -0.05em -0.025em 0 rgba(0, 255, 0, 0.75),
                   -0.025em 0.05em 0 rgba(0, 0, 255, 0.75);
    }
    14% {
      text-shadow: 0.05em 0 0 rgba(255, 0, 0, 0.75),
                   -0.05em -0.025em 0 rgba(0, 255, 0, 0.75),
                   -0.025em 0.05em 0 rgba(0, 0, 255, 0.75);
    }
    15% {
      text-shadow: -0.05em -0.025em 0 rgba(255, 0, 0, 0.75),
                   0.025em 0.025em 0 rgba(0, 255, 0, 0.75),
                   -0.05em -0.05em 0 rgba(0, 0, 255, 0.75);
    }
    49% {
      text-shadow: -0.05em -0.025em 0 rgba(255, 0, 0, 0.75),
                   0.025em 0.025em 0 rgba(0, 255, 0, 0.75),
                   -0.05em -0.05em 0 rgba(0, 0, 255, 0.75);
    }
    50% {
      text-shadow: 0.025em 0.05em 0 rgba(255, 0, 0, 0.75),
                   0.05em 0 0 rgba(0, 255, 0, 0.75),
                   0 -0.05em 0 rgba(0, 0, 255, 0.75);
    }
    99% {
      text-shadow: 0.025em 0.05em 0 rgba(255, 0, 0, 0.75),
                   0.05em 0 0 rgba(0, 255, 0, 0.75),
                   0 -0.05em 0 rgba(0, 0, 255, 0.75);
    }
    100% {
      text-shadow: -0.025em 0 0 rgba(255, 0, 0, 0.75),
                   -0.025em -0.025em 0 rgba(0, 255, 0, 0.75),
                   -0.025em -0.05em 0 rgba(0, 0, 255, 0.75);
    }
  }
</style>
