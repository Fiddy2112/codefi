---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturesSummary from '@/components/sections/Features.astro';
import FeatureWalkthrough from '@/components/sections/FeatureWalkthrough.astro';
import Commands from '@/components/sections/Commands.astro';
import InstallInstructions from '@/components/sections/InstallInstructions.astro';
import Footer from '@/components/sections/Footer.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout title="Features | CodeFi - Professional Flow State Tools">
  <!-- Hero Section for Features Page -->
  <section class="relative pt-32 pb-20 px-4 overflow-hidden">
    <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
    
    <div class="relative max-w-7xl mx-auto text-center">
      <div class="inline-block px-4 py-1.5 rounded-full bg-neon-green/10 border border-neon-green/20 text-neon-green text-sm font-mono mb-6">
        CORE MODULES v0.1.0
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 tracking-tight">
        Next-Gen <span class="neon-text">Flow</span> Infrastructure
      </h1>
      <p class="text-cyber-text text-xl max-w-3xl mx-auto leading-relaxed">
        Everything you need to eliminate cognitive friction and maximize output. 
        Zero UI distraction, pure terminal efficiency.
      </p>
    </div>
  </section>

  <!-- Detailed Walkthroughs -->
  <FeatureWalkthrough />

  <!-- Grid Summary -->
  <div class="bg-cyber-darker/30">
    <FeaturesSummary />
  </div>

  <!-- Command Reference -->
  <Commands />

  <InstallInstructions />

  <!-- Call to Action -->
  <section class="py-32 px-4 bg-cyber-black text-center relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-24 bg-gradient-to-b from-transparent to-neon-green/50"></div>
    
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">
        Built for the <span class="text-neon-green italic">Modern Architect</span>
      </h2>
      <p class="text-cyber-text text-lg mb-12">
        Join hundreds of developers brewing their perfect coding environment.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button variant="primary" size="lg" class="min-w-[200px]">
          Install CLI
        </Button>
        <a href="/pricing" class="inline-flex items-center px-8 py-3 rounded-lg border border-cyber-gray text-white font-medium hover:bg-white/5 transition-colors">
          View Plans
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .neon-text {
    color: #00FF41;
    text-shadow: 0 0 20px rgba(0, 255, 65, 0.4);
  }

  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(0, 255, 65, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 65, 0.1) 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>
