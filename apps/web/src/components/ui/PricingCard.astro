---
interface Props {
    title: string;
    subtitle: string;
    price: string;
    period?: string;
    features: string[];
    highlighted?: boolean;
    ctaText: string;
    ctaLink?: string;
}

const { 
  title, 
  subtitle, 
  price, 
  period = '/month',
  features, 
  highlighted = false,
  ctaText,
  ctaLink = '#'
} = Astro.props;

import Button from './Button.astro';
---

<div class={`pricing-card relative bg-cyber-dark rounded-2xl p-8 transition-all duration-300 ${highlighted ? 'border-2 border-neon-green shadow-neon-lg scale-105' : 'border border-cyber-gray hover:border-neon-green'}`}>
  
    {highlighted && (
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-neon-green text-cyber-black px-4 py-1 rounded-full text-sm font-bold z-20">
        POPULAR
      </div>
    )}
  
    <!-- Header -->
    <div class="text-center mb-8">
      <h3 class="text-2xl font-bold text-white mb-2">{title}</h3>
      <p class="text-cyber-text text-sm mb-6">{subtitle}</p>
      
      <div class="flex items-baseline justify-center gap-2">
        <span class="text-5xl font-bold text-neon-green">{price}</span>
        {price !== 'Free' && (
          <span class="text-cyber-text text-lg">{period}</span>
        )}
      </div>
    </div>
  
    <!-- Features -->
    <ul class="space-y-4 mb-8">
      {features.map((feature) => (
        <li class="flex items-start gap-3">
          <span class="text-neon-green text-xl flex-shrink-0">✓</span>
          <span class="text-cyber-text text-sm leading-relaxed">{feature}</span>
        </li>
      ))}
    </ul>
  
    <!-- CTA -->
    <Button 
      variant={highlighted ? 'primary' : 'secondary'} 
      size="lg" 
      href={ctaLink}
      class="w-full"
    >
      {ctaText}
    </Button>
  </div>
  
  <style>
    .pricing-card {
      position: relative;
      /* overflow: hidden; */
    }
    
    .pricing-card::after {
      content: '';
      position: absolute;
      top: -50%;
      right: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(
        circle,
        rgba(0, 255, 65, 0.05) 0%,
        transparent 70%
      );
      opacity: 0;
      transition: opacity 0.5s;
    }
    
    .pricing-card:hover::after {
      opacity: 1;
    }
  </style>