---
import Layout from "@/layouts/Layout.astro";
---

<script type="module">
  import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const params = new URLSearchParams(window.location.search);
  const redirectBase = params.get("redirect");      // http://localhost:43721/callback
  const codeChallenge = params.get("code_challenge");
  const state = params.get("state");
  const errorEl = document.getElementById("error");

  if (!redirectBase || !state) {
    document.body.innerHTML = `<p style="color:white;text-align:center;margin-top:50px">
      Missing required parameters. Please run <code>codefi login</code> again.
    </p>`;
    throw new Error("Missing params");
  }

  // if got session after OAuth redirect → forward to CLI
  const { data: sessionData } = await supabase.auth.getSession();
  if (sessionData.session) {

    const urlCode = new URLSearchParams(window.location.search).get('code');
    if (urlCode) {
      window.location.href = `${redirectBase}?code=${urlCode}&state=${state}`;
      return;
    }
  }

  function showError(msg) {
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  // Email login
  document.getElementById("login-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    errorEl.classList.add("hidden");

    const email = document.getElementById("email").value;
    const password = document.getElementById("password").value;

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) return showError(error.message);
    if (!data.session) return showError("Login failed: no session");

    const { data: pkceData, error: pkceError } = await supabase.auth.exchangeCodeForSession(
      data.session.access_token
    );

    window.location.href = `${redirectBase}?code=${data.session.access_token}&state=${state}`;
  });

  document.getElementById("google-login").addEventListener("click", async () => {
    await supabase.auth.signInWithOAuth({
      provider: "google",
      options: {
        redirectTo: window.location.href,
        queryParams: { code_challenge: codeChallenge, code_challenge_method: 'S256' }
      }
    });
  });

  // GitHub OAuth
  document.getElementById("github-login").addEventListener("click", async () => {
    await supabase.auth.signInWithOAuth({
      provider: "github",
      options: {
        redirectTo: window.location.href,
        queryParams: { code_challenge: codeChallenge, code_challenge_method: 'S256' }
      }
    });
  });
</script>