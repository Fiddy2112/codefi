---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Codefi CLI Login">
  <section class="relative min-h-screen flex items-center justify-center px-4 bg-cyber-black">
    <div class="w-full max-w-md">

      <!-- Header -->
      <div class="text-center mb-10">
        <h1 class="text-4xl font-bold text-white mb-3">
          Connect Your<br />
          <span class="neon-text">Codefi CLI</span>
        </h1>
        <p id="header-sub" class="text-cyber-text text-sm">
          Authenticate to unlock Pro features in your terminal.
        </p>
      </div>

      <!-- Card -->
      <div class="bg-neutral-900/60 backdrop-blur border border-neutral-800 rounded-2xl p-8 shadow-xl space-y-6">

        <!-- Tab toggle -->
        <div class="flex rounded-lg border border-neutral-700 overflow-hidden">
          <button
            id="tab-login"
            class="flex-1 py-2 text-sm font-mono font-semibold transition-all duration-200 bg-neon-green text-black"
          >
            Login
          </button>
          <button
            id="tab-signup"
            class="flex-1 py-2 text-sm font-mono font-semibold transition-all duration-200 text-neutral-400 hover:text-white"
          >
            Sign Up
          </button>
        </div>

        <!-- OAuth Buttons -->
        <div class="space-y-3">
          <button
            id="google-login"
            data-label-login="Continue with Google"
            data-label-signup="Sign up with Google"
            class="w-full py-2 rounded-lg border border-neon-green text-neon-green font-mono font-semibold hover:bg-neon-green hover:text-black transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Continue with Google
          </button>
          <button
            id="github-login"
            data-label-login="Continue with GitHub"
            data-label-signup="Sign up with GitHub"
            class="w-full py-2 rounded-lg border border-neon-green text-neon-green font-mono font-semibold hover:bg-neon-green hover:text-black transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Continue with GitHub
          </button>
        </div>

        <!-- Divider -->
        <div class="flex items-center gap-3">
          <div class="flex-1 h-px bg-neutral-800"></div>
          <span class="text-xs text-cyber-text font-mono">OR</span>
          <div class="flex-1 h-px bg-neutral-800"></div>
        </div>

        <!-- ── LOGIN FORM ── -->
        <form id="login-form" class="space-y-4">
          <input type="email" id="login-email" placeholder="Email" required autocomplete="email"
            class="w-full px-4 py-2 rounded-lg bg-neutral-800 border border-neutral-700 focus:outline-none focus:border-neon-green text-white placeholder-neutral-500" />
          <input type="password" id="login-password" placeholder="Password" required autocomplete="current-password"
            class="w-full px-4 py-2 rounded-lg bg-neutral-800 border border-neutral-700 focus:outline-none focus:border-neon-green text-white placeholder-neutral-500" />
          <button type="submit" id="login-submit" data-label="Login with Email"
            class="w-full py-2 rounded-lg border border-neon-green text-neon-green font-mono font-semibold hover:bg-neon-green hover:text-black transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
            Login with Email
          </button>
        </form>

        <!-- ── SIGNUP FORM ── -->
        <form id="signup-form" class="space-y-4 hidden">
          <input type="email" id="signup-email" placeholder="Email" required autocomplete="email"
            class="w-full px-4 py-2 rounded-lg bg-neutral-800 border border-neutral-700 focus:outline-none focus:border-neon-green text-white placeholder-neutral-500" />
          <input type="password" id="signup-password" placeholder="Password (min 8 characters)" required autocomplete="new-password" minlength="8"
            class="w-full px-4 py-2 rounded-lg bg-neutral-800 border border-neutral-700 focus:outline-none focus:border-neon-green text-white placeholder-neutral-500" />
          <input type="password" id="signup-confirm" placeholder="Confirm password" required autocomplete="new-password"
            class="w-full px-4 py-2 rounded-lg bg-neutral-800 border border-neutral-700 focus:outline-none focus:border-neon-green text-white placeholder-neutral-500" />
          <button type="submit" id="signup-submit" data-label="Create Account"
            class="w-full py-2 rounded-lg border border-neon-green text-neon-green font-mono font-semibold hover:bg-neon-green hover:text-black transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed">
            Create Account
          </button>
        </form>

        <!-- Status messages -->
        <p id="error" class="text-red-400 text-sm hidden font-mono"></p>
        <p id="info"  class="text-green-400 text-sm hidden font-mono text-center"></p>

      </div>
    </div>
  </section>

  <style>
    .neon-text {
      background: linear-gradient(135deg, #00FF41 0%, #00cc33 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .tab-active   { background-color: #00FF41; color: #000; }
    .tab-inactive { background-color: transparent; color: #737373; }
    .tab-inactive:hover { color: #fff; }
  </style>

  <script type="module">
    import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

    // ── Env check ──────────────────────────────────────────────────────────────
    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    if (!SUPABASE_URL || !SUPABASE_KEY) {
      document.querySelector("section").innerHTML = `
        <div style="color:white;text-align:center;padding:80px 24px;font-family:monospace">
          <div style="font-size:48px;color:#ff4444">✗</div>
          <div style="font-size:20px;margin-top:16px">Configuration error</div>
          <div style="color:#888;margin-top:8px">
            Missing <code style="color:#00FF41">PUBLIC_SUPABASE_URL</code> or
            <code style="color:#00FF41">PUBLIC_SUPABASE_ANON_KEY</code>.<br/>
            Add them to your Vercel project settings.
          </div>
        </div>`;
      throw new Error("Missing Supabase env vars");
    }

    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

    // ── URL params ─────────────────────────────────────────────────────────────
    const params       = new URLSearchParams(window.location.search);
    const redirectBase = params.get("redirect");
    const state        = params.get("state");

    if (!redirectBase || !state) {
      document.querySelector("section").innerHTML = `
        <div style="color:white;text-align:center;padding:80px 24px;font-family:monospace">
          <div style="font-size:48px;color:#ff4444">✗</div>
          <div style="font-size:20px;margin-top:16px">Missing parameters</div>
          <div style="color:#888;margin-top:8px">
            Please run <code style="color:#00FF41">codefi login</code> again.
          </div>
        </div>`;
      throw new Error("Missing redirect or state param");
    }

    // ── DOM refs ───────────────────────────────────────────────────────────────
    const errorEl       = document.getElementById("error");
    const infoEl        = document.getElementById("info");
    const tabLogin      = document.getElementById("tab-login");
    const tabSignup     = document.getElementById("tab-signup");
    const loginForm     = document.getElementById("login-form");
    const signupForm    = document.getElementById("signup-form");
    const headerSub     = document.getElementById("header-sub");
    const googleBtn     = document.getElementById("google-login");
    const githubBtn     = document.getElementById("github-login");

    // ── Helpers ────────────────────────────────────────────────────────────────
    function forwardToCLI(accessToken, refreshToken) {
      showInfo("✓ Success! Redirecting back to terminal...");
      const url = new URL(redirectBase);
      url.searchParams.set("access_token",  accessToken);
      url.searchParams.set("refresh_token", refreshToken || "");
      url.searchParams.set("state",         state);
      setTimeout(() => { window.location.href = url.toString(); }, 700);
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove("hidden");
      infoEl.classList.add("hidden");
    }

    function showInfo(msg) {
      infoEl.textContent = msg;
      infoEl.classList.remove("hidden");
      errorEl.classList.add("hidden");
    }

    function clearMessages() {
      errorEl.classList.add("hidden");
      infoEl.classList.add("hidden");
    }

    function setLoading(btn, loading) {
      btn.disabled    = loading;
      btn.textContent = loading ? "Loading..." : btn.dataset.label;
    }

    // ── Tab switching ──────────────────────────────────────────────────────────
    let currentTab = "login";

    function switchTab(tab) {
      currentTab = tab;
      clearMessages();

      if (tab === "login") {
        tabLogin.className  = "flex-1 py-2 text-sm font-mono font-semibold transition-all duration-200 tab-active";
        tabSignup.className = "flex-1 py-2 text-sm font-mono font-semibold transition-all duration-200 tab-inactive";
        loginForm.classList.remove("hidden");
        signupForm.classList.add("hidden");
        headerSub.textContent = "Authenticate to unlock Pro features in your terminal.";
        googleBtn.textContent = googleBtn.dataset.labelLogin;
        githubBtn.textContent = githubBtn.dataset.labelLogin;
      } else {
        tabSignup.className = "flex-1 py-2 text-sm font-mono font-semibold transition-all duration-200 tab-active";
        tabLogin.className  = "flex-1 py-2 text-sm font-mono font-semibold transition-all duration-200 tab-inactive";
        signupForm.classList.remove("hidden");
        loginForm.classList.add("hidden");
        headerSub.textContent = "Create your account to get started.";
        googleBtn.textContent = googleBtn.dataset.labelSignup;
        githubBtn.textContent = githubBtn.dataset.labelSignup;
      }
    }

    tabLogin.addEventListener("click",  () => switchTab("login"));
    tabSignup.addEventListener("click", () => switchTab("signup"));

    // ── OAuth redirect check ───────────────────────────────────────────────────
    const hash        = new URLSearchParams(window.location.hash.replace(/^#/, ""));
    const hashToken   = hash.get("access_token");
    const hashRefresh = hash.get("refresh_token");

    if (hashToken) {
      forwardToCLI(hashToken, hashRefresh || "");
    } else {
      const { data: { session } } = await supabase.auth.getSession();
      if (session?.access_token) {
        forwardToCLI(session.access_token, session.refresh_token);
      }
    }

    // ── Email login ────────────────────────────────────────────────────────────
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearMessages();

      const submitBtn = document.getElementById("login-submit");
      setLoading(submitBtn, true);

      const email    = document.getElementById("login-email").value.trim();
      const password = document.getElementById("login-password").value;

      const { data, error } = await supabase.auth.signInWithPassword({ email, password });

      if (error) {
        setLoading(submitBtn, false);
        // Friendly message for wrong credentials
        if (error.message.toLowerCase().includes("invalid")) {
          return showError("Incorrect email or password. Try again or switch to Sign Up.");
        }
        return showError(error.message);
      }

      if (!data.session?.access_token) {
        setLoading(submitBtn, false);
        return showError("Login failed: no session returned. Please try again.");
      }

      forwardToCLI(data.session.access_token, data.session.refresh_token);
    });

    // ── Email signup ───────────────────────────────────────────────────────────
    signupForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearMessages();

      const submitBtn  = document.getElementById("signup-submit");
      const email      = document.getElementById("signup-email").value.trim();
      const password   = document.getElementById("signup-password").value;
      const confirm    = document.getElementById("signup-confirm").value;

      // Client-side validation
      if (password.length < 8) {
        return showError("Password must be at least 8 characters.");
      }
      if (password !== confirm) {
        return showError("Passwords do not match.");
      }

      setLoading(submitBtn, true);

      const { data, error } = await supabase.auth.signUp({ email, password });

      if (error) {
        setLoading(submitBtn, false);
        if (error.message.toLowerCase().includes("already registered")) {
          showError("This email is already registered. Switch to Login.");
          setTimeout(() => switchTab("login"), 1500);
          return;
        }
        return showError(error.message);
      }

      // Supabase may require email confirmation depending on project settings
      if (data.session?.access_token) {
        // Email confirmation disabled → logged in immediately
        forwardToCLI(data.session.access_token, data.session.refresh_token);
      } else {
        // Email confirmation enabled → ask user to check inbox
        setLoading(submitBtn, false);
        showInfo("✓ Account created! Check your email to confirm, then come back and log in.");
        setTimeout(() => switchTab("login"), 3000);
      }
    });

    // ── OAuth ──────────────────────────────────────────────────────────────────
    async function startOAuth(provider) {
      const btn = provider === "google" ? googleBtn : githubBtn;
      setLoading(btn, true);
      clearMessages();

      const { data, error } = await supabase.auth.signInWithOAuth({
        provider,
        options: {
          redirectTo: window.location.href,
          skipBrowserRedirect: false,
        },
      });

      if (error) {
        setLoading(btn, false);
        if (error.message.includes("provider is not enabled")) {
          return showError(
            `${provider} is not enabled. ` +
            `Go to Supabase → Authentication → Providers to enable it.`
          );
        }
        return showError(error.message);
      }

      if (data?.url) {
        window.location.href = data.url;
      } else {
        setLoading(btn, false);
        showError(
          `Could not start ${provider} login. ` +
          `Make sure it's enabled in your Supabase project.`
        );
      }
    }

    googleBtn.addEventListener("click", () => startOAuth("google"));
    githubBtn.addEventListener("click", () => startOAuth("github"));
  </script>
</Layout>