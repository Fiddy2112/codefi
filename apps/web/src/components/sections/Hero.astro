---
import Button from "@/components/ui/Button.astro"
---

<section class="relative min-h-screen flex items-center justify-center px-4 py-20 overflow-hidden">
    <!-- Background Grid Effect -->
    <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>

    <!-- Gradient Orbs -->
    <!-- <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-neon-green opacity-10 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-neon-green opacity-5 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div> -->

    <div class="relative max-w-6xl mx-auto text-center">
        <!-- Main Heading -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6">
            <span class="text-white">Flow State</span><br/>
            <span class="neon-text">On Command.</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-cyber-text text-lg md:text-xl max-w-2xl mx-auto mb-8 leading-relaxed">
            Lofi, Synthwave, and Code-flavored<br class="hidden md:block"/>
            Intensity at typing-level sync.
        </p>

        <div class="terminal-box rounded-2xl shadow-lg shadow-neon-green">
            <!-- Terminal Header -->
            <div class="inline-flex w-full items-center gap-2 bg-cyber-darker border border-cyber-gray rounded-t-lg px-4 py-2 mb-0">
                <div class="flex gap-2">
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                </div>
                <span class="text-cyber-text text-xs font-mono ml-4">zsh - dev-music</span>
            </div>

            <!-- Terminal Content -->
            <div class=" bg-cyber-darker border-2 border-cyber-gray rounded-b-2xl p-8 md:p-12 shadow-2xl">
                <!-- Terminal Lines with Animation -->
                <div class="text-left mb-8 space-y-2 font-mono text-sm md:text-base">
                    <div class="terminal-line opacity-0 animate-fade-in" style="animation-delay: 0.2s;">
                    <span class="text-neon-green">$</span> npm install -g @felizz23/codefi
                    </div>
                    <div class="terminal-line opacity-0 animate-fade-in" style="animation-delay: 0.5s;">
                    <span class="text-neon-green">$</span> codefi play --mood focus
                    </div>
                    <div class=" opacity-0 animate-fade-in text-cyber-text" style="animation-delay: 0.8s;">
                        Connecting <span class="animate-bounce">...</span>
                    </div>
                    <div class="terminal-line opacity-0 animate-fade-in text-cyber-text" style="animation-delay: 0.8s;">
                    🎧 Now playing: Deep Focus Mix
                    </div>
                    <div class="terminal-line opacity-0 animate-fade-in text-neon-green" style="animation-delay: 1.1s;">
                    ⚡ Flow state: ACTIVATED
                    </div>
                </div>
            </div>
        </div>
        
    </div>
</section>

<style>
    .bg-grid-pattern {
      background-image: 
        linear-gradient(rgba(0, 255, 65, 0.1) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 65, 0.1) 1px, transparent 1px);
      background-size: 50px 50px;
    }
  
    .terminal-box {
      position: relative;
    }
  
    .terminal-box::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      padding: 2px;
      background: linear-gradient(135deg, transparent, rgba(0, 255, 65, 0.3), transparent);
      -webkit-mask: 
        linear-gradient(#fff 0 0) content-box, 
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.5s;
    }
  
    .terminal-box:hover::before {
      opacity: 1;
    }
  
    @keyframes fade-in {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  
    .animate-fade-in {
      animation: fade-in 0.5s ease-out forwards;
    }
  
    .terminal-line {
      color: rgba(224, 224, 224, 0.9);
    }
  
    .neon-text {
      animation: glow 2s ease-in-out infinite alternate;
    }
  </style>