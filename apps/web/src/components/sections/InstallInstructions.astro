---
---

<section id="install" class="py-24 px-4 bg-cyber-dark relative overflow-hidden">
  <div class="absolute inset-0 bg-grid-pattern opacity-5"></div>
  
  <div class="max-w-4xl mx-auto text-center relative">
    <div class="inline-block px-3 py-1 rounded bg-neon-green/10 border border-neon-green/20 text-neon-green text-xs font-mono mb-6">
      GETTING STARTED
    </div>
    <h2 class="text-4xl font-bold text-white mb-8">
      Brewing Your <span class="neon-text">Soundtrack</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
      <!-- Step 1 -->
      <div class="space-y-4">
        <div class="w-10 h-10 rounded-full bg-neon-green text-cyber-black flex items-center justify-center font-bold">1</div>
        <h3 class="text-white font-bold">Install Node.js</h3>
        <p class="text-cyber-text text-sm">Download Node.js 18+ for your system.</p>
      </div>

      <!-- Step 2 -->
      <div class="space-y-4">
        <div class="w-10 h-10 rounded-full bg-neon-green text-cyber-black flex items-center justify-center font-bold">2</div>
        <h3 class="text-white font-bold">The Command</h3>
        <div class="bg-cyber-black p-3 rounded border border-cyber-gray font-mono text-xs text-neon-green">
          npm install -g @codefi/cli
        </div>
      </div>

      <!-- Step 3 -->
      <div class="space-y-4">
        <div class="w-10 h-10 rounded-full bg-neon-green text-cyber-black flex items-center justify-center font-bold">3</div>
        <h3 class="text-white font-bold">Enter Flow</h3>
        <p class="text-cyber-text text-sm">Type <code class="text-white">codefi play</code> and enjoy.</p>
      </div>
    </div>

    <!-- Troubleshooting -->
    <div class="mt-16 p-6 rounded-xl bg-cyber-darker border border-cyber-gray text-left">
      <h4 class="text-white font-bold mb-4 flex items-center gap-2">
        <span class="text-neon-green">!</span> Troubleshooting
      </h4>
      <p class="text-cyber-text text-sm mb-4">
        Running into issues? Most common problems are solved by checking dependencies:
      </p>
      <div class="bg-cyber-black p-4 rounded-lg font-mono text-sm text-cyber-text">
        <span class="text-neon-green">$</span> codefi doctor
      </div>
    </div>
  </div>
</section>

<style>
  .neon-text {
    color: #00FF41;
    text-shadow: 0 0 10px rgba(0, 255, 65, 0.4);
  }
  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(0, 255, 65, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 65, 0.1) 1px, transparent 1px);
    background-size: 30px 30px;
  }
</style>
