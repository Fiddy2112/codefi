---

import PricingCard from '../ui/PricingCard.astro';

const plans = [
  {
    title: 'Bedroom Coder',
    subtitle: 'Perfect for solo developers',
    price: 'Free',
    period: '',
    features: [
      '10 Built-in Lofi/Synthwave tracks',
      'Basic mood selection (Focus, Chill)',
      'CLI access with core commands',
      'Local playback only',
      'Community support'
    ],
    highlighted: false,
    ctaText: 'Get Started - Free',
    ctaLink: '#install'
  },
  {
    title: 'Production Pro',
    subtitle: 'For serious flow seekers',
    price: '$5',
    period: '/month',
    features: [
      '100+ curated tracks library',
      'Spotify integration & control',
      'AI mood detection & auto-adjustment',
      'Pomodoro timer with auto-pause',
      'Custom playlists & sharing',
      'Cross-device session sync',
      'Advanced analytics dashboard',
      'Priority support'
    ],
    highlighted: true,
    ctaText: 'Upgrade to Pro',
    ctaLink: '#upgrade'
  }
];
---

<section id="pricing" class="relative py-20 px-4 bg-cyber-darker">
  <div class="max-w-6xl mx-auto">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Simple, Transparent<br/>
        <span class="neon-text">Pricing</span>
      </h2>
      <p class="text-cyber-text text-lg max-w-2xl mx-auto">
        Start free. Upgrade when you're ready.<br class="hidden md:block"/>
        No credit card required for free tier.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <PricingCard 
          title={plan.title}
          subtitle={plan.subtitle}
          price={plan.price}
          period={plan.period}
          features={plan.features}
          highlighted={plan.highlighted}
          ctaText={plan.ctaText}
          ctaLink={plan.ctaLink}
        />
      ))}
    </div>

    <!-- FAQ Link -->
    <div class="text-center mt-16">
      <p class="text-cyber-text text-sm mb-4">
        Questions about pricing?
      </p>
      <a 
        href="#faq" 
        class="inline-flex items-center gap-2 text-neon-green hover:text-neon-green-dark transition-colors group font-mono"
      >
        <span>Check our FAQ</span>
        <span class="transform group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

    <!-- Trust Badges -->
    <div class="flex flex-wrap items-center justify-center gap-8 mt-16 pt-16 border-t border-cyber-gray">
      <div class="flex items-center gap-2 text-cyber-text">
        <span class="text-neon-green text-2xl">✓</span>
        <span class="text-sm">Cancel anytime</span>
      </div>
      <div class="flex items-center gap-2 text-cyber-text">
        <span class="text-neon-green text-2xl">✓</span>
        <span class="text-sm">Secure payments</span>
      </div>
      <div class="flex items-center gap-2 text-cyber-text">
        <span class="text-neon-green text-2xl">✓</span>
        <span class="text-sm">14-day money back</span>
      </div>
    </div>
  </div>
</section>

<style>
  .neon-text {
    background: linear-gradient(135deg, #00FF41 0%, #00cc33 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>