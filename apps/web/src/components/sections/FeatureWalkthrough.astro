---
const walkthroughs = [
  {
    title: "AI-Powered Mood Detection",
    description: "CodeFi analyzes your coding patterns (or manual prompt) to select the perfect soundtrack. Whether you're in a 'debugging frenzy' or 'zen flow', the music adapts.",
    demo: [
      { type: 'input', text: 'codefi play --ai-mood' },
      { type: 'output', text: '🔍 Analyzing session context...' },
      { type: 'output', text: '🧠 Mood detected: "Intense Debugging"' },
      { type: 'output', text: '🎧 Switching to: High-Tempo Cyber-Synth' },
      { type: 'success', text: '⚡ Flow state: RE-SYNCHRONIZED' }
    ],
    icon: '🧠'
  },
  {
    title: "Global Spotify & YouTube Integration",
    description: "Access millions of tracks without leaving your terminal. Stream directly from YouTube or sync your Spotify Liked Songs.",
    demo: [
      { type: 'input', text: 'codefi play --youtube "synthwave radio"' },
      { type: 'output', text: '📡 Fetching stream from YouTube...' },
      { type: 'output', text: '🎵 Streaming: 24/7 Synthwave Chill Station' },
      { type: 'input', text: 'codefi spotify connect' },
      { type: 'output', text: '✅ Spotify Linked: @fiddy2112' }
    ],
    icon: '🌐'
  },
  {
    title: "Integrated Pomodoro Engine",
    description: "Stay productive with a built-in timer that manages your music. Music fades out during breaks and ramps up when it's time to focus.",
    demo: [
      { type: 'input', text: 'codefi pomodoro start' },
      { type: 'output', text: '⏱️ Pomodoro started: 25:00' },
      { type: 'output', text: '🎵 Background: Deep Focus Beats' },
      { type: 'output', text: '...' },
      { type: 'success', text: '🔔 Time for a break! (5:00)' },
      { type: 'output', text: '⏸️ Music paused.' }
    ],
    icon: '⏱️'
  }
];
---

<section class="py-24 px-4 bg-cyber-black">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Deep Dive Into <span class="neon-text">Precision</span>
      </h2>
      <p class="text-cyber-text text-lg max-w-3xl mx-auto">
        Every feature is engineered for the terminal-first developer. 
        Minimal latency, maximum focus.
      </p>
    </div>

    <div class="space-y-32">
      {walkthroughs.map((w, index) => (
        <div class={`flex flex-col lg:items-center gap-12 ${index % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>
          <!-- Text Content -->
          <div class="flex-1 space-y-6">
            <div class="flex items-center gap-4">
              <span class="text-4xl">{w.icon}</span>
              <h3 class="text-2xl md:text-3xl font-bold text-white">{w.title}</h3>
            </div>
            <p class="text-cyber-text text-lg leading-relaxed">
              {w.description}
            </p>
            <ul class="space-y-3">
               <li class="flex items-center gap-3 text-neon-green/80">
                 <span class="w-1.5 h-1.5 rounded-full bg-neon-green"></span>
                 Low CPU overhead
               </li>
               <li class="flex items-center gap-3 text-neon-green/80">
                 <span class="w-1.5 h-1.5 rounded-full bg-neon-green"></span>
                 No browser tabs required
               </li>
            </ul>
          </div>

          <!-- Terminal Demo -->
          <div class="flex-1">
            <div class="terminal-shell rounded-xl overflow-hidden shadow-2xl border border-cyber-gray bg-cyber-darker">
              <div class="flex items-center gap-2 px-4 py-3 bg-cyber-gray/20 border-b border-cyber-gray">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                  <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
                </div>
                <span class="text-xs font-mono text-cyber-text opacity-50 ml-2">codefi --terminal</span>
              </div>
              <div class="p-6 font-mono text-sm md:text-base space-y-3">
                {w.demo.map((line) => (
                  <div class="flex gap-3">
                    {line.type === 'input' && <span class="text-neon-green select-none">$</span>}
                    <span class={
                      line.type === 'input' ? 'text-white' : 
                      line.type === 'success' ? 'text-neon-green font-bold' : 
                      'text-cyber-text'
                    }>
                      {line.text}
                    </span>
                  </div>
                ))}
                <div class="animate-pulse inline-block w-2 h-5 bg-neon-green ml-1 translate-y-1"></div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .neon-text {
    color: #00FF41;
    text-shadow: 0 0 10px rgba(0, 255, 65, 0.3);
  }

  .terminal-shell {
    transform: perspective(1000px) rotateY(-5deg);
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .terminal-shell:hover {
    transform: perspective(1000px) rotateY(0deg) scale(1.02);
  }

  /* Different tilt for alternating items */
  div:nth-child(even) .terminal-shell {
    transform: perspective(1000px) rotateY(5deg);
  }

  div:nth-child(even) .terminal-shell:hover {
    transform: perspective(1000px) rotateY(0deg) scale(1.02);
  }
</style>
