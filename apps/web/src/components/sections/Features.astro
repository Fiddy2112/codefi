---

import FeatureCard from '../ui/FeatureCard.astro';

const features = [
  {
    icon: '🎵',
    title: 'Built-in Lofi Library',
    description: 'Curated Lofi & Synthwave tracks. Zero setup, zero distraction. Just pure focus.'
  },
  {
    icon: '🎧',
    title: 'Spotify Integration',
    description: 'Connect your Spotify. Control playback from terminal. Your playlists, our interface.'
  },
  {
    icon: '🧠',
    title: 'AI Mood Detection',
    description: 'Detects "debugging panic" vs "deep focus". Adjusts tempo & intensity automatically.'
  },
  {
    icon: '⏱️',
    title: 'Pomodoro Timer',
    description: '25min work, 5min break. Integrated timer with music auto-pause. Stay in flow.'
  },
  {
    icon: '📊',
    title: 'Session Analytics',
    description: 'Track your coding sessions. See your most productive hours. Optimize your flow.'
  },
  {
    icon: '🎨',
    title: 'Custom Playlists',
    description: 'Create mood-based playlists. Share with your team. Build your perfect coding soundtrack.'
  }
];
---

<section class="relative py-20 px-4 bg-cyber-black">
  <div class="max-w-7xl mx-auto">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Everything You Need<br/>
        <span class="neon-text">To Enter Flow State</span>
      </h2>
      <p class="text-cyber-text text-lg max-w-2xl mx-auto mb-4">
        From terminal-native playback to AI-powered mood detection,<br class="hidden md:block"/>
        CodeFi has everything to keep you in the zone.
      </p>
      <a href="/features" class="text-neon-green hover:underline font-mono text-sm">View detailed walkthrough →</a>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <FeatureCard 
          icon={feature.icon}
          title={feature.title}
          description={feature.description}
        />
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <p class="text-cyber-text mb-4">
        Ready to level up your coding sessions?
      </p>
      <a 
        href="#pricing" 
        class="inline-flex items-center gap-2 text-neon-green hover:text-neon-green-dark transition-colors group"
      >
        <span class="font-mono font-semibold">Explore Pricing</span>
        <span class="transform group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .neon-text {
    background: linear-gradient(135deg, #00FF41 0%, #00cc33 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>