{
    "name": "codefi-monorepo",
    "version": "1.0.0",
    "private": true,
    "description": "CodeFi - Brewing beats for your code",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "pnpm --filter \"./apps/*\" dev",
        "dev:web": "pnpm --filter web dev",
        "dev:cli": "pnpm --filter cli dev",
        "dev:docs": "pnpm --filter docs dev",
        "build": "pnpm --filter \"./apps/*\" build",
        "build:web": "pnpm --filter web build",
        "build:cli": "pnpm --filter cli build",
        "lint": "pnpm --filter \"./apps/*\" lint",
        "test": "pnpm --filter \"./apps/*\" test",
        "format": "prettier --write \"**/*.{ts,tsx,md,json,astro}\"",
        "clean": "pnpm --filter \"./apps/*\" clean && rm -rf node_modules"
    },
    "devDependencies": {
        "@types/node": "^20.19.30",
        "@types/node-notifier": "^8.0.5",
        "@types/play-sound": "^1.1.2",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "pnpm": ">=8.0.0"
    },
    "packageManager": "pnpm@8.12.0",
    "dependencies": {
        "node-notifier": "^10.0.1"
    }
}
